<!-- JAVASCRIPT: LÓGICA DE CALIFICACIÓN                            -->
<!-- ============================================================ -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Arreglo con las respuestas correctas (en orden: q1 a q10)
        const respuestasCorrectas = ['b', 'c', 'a', 'c', 'b', 'a', 'a', 'a', 'a', 'a'];

        const btnCalificar = document.getElementById('btnCalificar');
        const modal = document.getElementById('modalResultados');
        const btnCerrar = document.getElementById('btnCerrarModal');
        const puntajeSpan = document.getElementById('puntajeMostrado');
        const detalleSpan = document.getElementById('detalleMostrado');

        function calificar() {
            let aciertos = 0;
            let total = respuestasCorrectas.length;
            let mensajes = [];

            for (let i = 1; i <= total; i++) {
                const name = 'q' + i;
                const seleccionado = document.querySelector(`input[name="${name}"]:checked`);
                const correcta = respuestasCorrectas[i - 1];

                if (seleccionado) {
                    if (seleccionado.value === correcta) {
                        aciertos++;
                    } else {
                        mensajes.push(`Pregunta ${i}: incorrecta (tu respuesta: ${seleccionado.value.toUpperCase()}, correcta: ${correcta.toUpperCase()})`);
                    }
                } else {
                    mensajes.push(`Pregunta ${i}: no respondida (correcta: ${correcta.toUpperCase()})`);
                }
            }

            // Mostrar modal
            puntajeSpan.textContent = `${aciertos} / ${total}`;
            if (aciertos === total) {
                detalleSpan.innerHTML = '🎉 ¡Perfecto! Todas las respuestas son correctas. ¡Eres un genio!';
            } else if (aciertos >= 7) {
                detalleSpan.innerHTML = `👍 Muy bien. Tienes ${aciertos} aciertos. Revisa los detalles abajo para mejorar.`;
            } else {
                detalleSpan.innerHTML = `📖 Sigue practicando. Tienes ${aciertos} aciertos. Revisa los ejercicios resueltos paso a paso.`;
            }

            // Agregar mensajes de detalle
            if (mensajes.length > 0) {
                let lista = '<ul style="text-align:left; margin-top:10px; font-size:0.9rem;">';
                mensajes.forEach(m => {
                    lista += `<li>${m}</li>`;
                });
                lista += '</ul>';
                detalleSpan.innerHTML += lista;
            }

            modal.classList.add('activo');
        }

        btnCalificar.addEventListener('click', calificar);

        btnCerrar.addEventListener('click', function() {
            modal.classList.remove('activo');
        });

        // Cerrar modal al hacer clic fuera del contenido
        modal.addEventListener('click', function(e) {
            if (e.target === modal) {
                modal.classList.remove('activo');
            }
        });

        // Cerrar con tecla ESC
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && modal.classList.contains('activo')) {
                modal.classList.remove('activo');
            }
        });
    });
</script>

